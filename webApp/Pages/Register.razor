@page "/register"
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Register — Workshop</PageTitle>

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --ink:      #0f0e0d;
        --paper:    #f5f0e8;
        --accent:   #c84b2f;
        --muted:    #8a8070;
        --border:   #d6cfc2;
        --field-bg: #ede8de;
    }

    html, body {
        height: 100%;
        background: var(--paper);
        color: var(--ink);
        font-family: 'DM Sans', sans-serif;
        font-weight: 300;
    }

    .page {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 480px 1fr;
    }

    .panel-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 3rem 3.5rem;
        background: var(--paper);
    }

    .form-header {
        margin-bottom: 2.5rem;
        opacity: 0;
        animation: rise .8s cubic-bezier(.16,1,.3,1) .2s forwards;
    }
    .form-header h1 {
        font-family: 'DM Serif Display', serif;
        font-size: 2rem;
        font-weight: 400;
        letter-spacing: -.01em;
        margin-bottom: .35rem;
    }
    .form-header p { font-size: .875rem; color: var(--muted); }

    .register-form { display: flex; flex-direction: column; gap: 1.1rem; }

    .field-group {
        opacity: 0;
        animation: rise .8s cubic-bezier(.16,1,.3,1) forwards;
    }
    .field-group:nth-child(1) { animation-delay: .35s; }
    .field-group:nth-child(2) { animation-delay: .42s; }
    .field-group:nth-child(3) { animation-delay: .49s; }
    .field-group:nth-child(4) { animation-delay: .56s; }
    .field-group:nth-child(5) { animation-delay: .63s; }

    .field-group label {
        display: block;
        font-size: .75rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .5rem;
    }
    .field-group input {
        width: 100%;
        padding: .85rem 1rem;
        background: var(--field-bg);
        border: 1.5px solid transparent;
        border-radius: 6px;
        font-family: 'DM Sans', sans-serif;
        font-size: .95rem;
        color: var(--ink);
        transition: border-color .2s, background .2s;
        outline: none;
    }
    .field-group input:focus { border-color: var(--accent); background: #fff; }
    .field-group input::placeholder { color: var(--muted); }
    .field-group input.invalid { border-color: var(--accent); }

    .field-error {
        display: block;
        margin-top: .35rem;
        font-size: .78rem;
        color: var(--accent);
    }

    .alert-error {
        background: #fdf0ed;
        border: 1px solid #f2c4b8;
        border-left: 3px solid var(--accent);
        border-radius: 6px;
        padding: .75rem 1rem;
        font-size: .85rem;
        color: #8b2615;
        margin-bottom: 1rem;
        animation: rise .5s cubic-bezier(.16,1,.3,1) forwards;
    }

    .alert-success {
        background: #edf7f0;
        border: 1px solid #b4dfc2;
        border-left: 3px solid #2f9e57;
        border-radius: 6px;
        padding: .75rem 1rem;
        font-size: .85rem;
        color: #1a5c35;
        margin-bottom: 1rem;
        animation: rise .5s cubic-bezier(.16,1,.3,1) forwards;
    }

    .btn-register {
        margin-top: .5rem;
        padding: .9rem;
        background: var(--ink);
        color: var(--paper);
        font-family: 'DM Sans', sans-serif;
        font-size: .9rem;
        font-weight: 500;
        letter-spacing: .06em;
        text-transform: uppercase;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        width: 100%;
        opacity: 0;
        animation: rise .8s cubic-bezier(.16,1,.3,1) .75s forwards;
    }
    .btn-register::after {
        content: '';
        position: absolute;
        inset: 0;
        background: var(--accent);
        transform: translateX(-100%);
        transition: transform .35s cubic-bezier(.16,1,.3,1);
    }
    .btn-register:hover::after { transform: translateX(0); }
    .btn-register:disabled { opacity: .6; cursor: not-allowed; }
    .btn-register span { position: relative; z-index: 1; }

    .divider {
        display: flex;
        align-items: center;
        gap: .75rem;
        color: var(--muted);
        font-size: .78rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        opacity: 0;
        animation: rise .8s cubic-bezier(.16,1,.3,1) .85s forwards;
    }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    .footer-note {
        text-align: center;
        font-size: .82rem;
        color: var(--muted);
        opacity: 0;
        animation: rise .8s cubic-bezier(.16,1,.3,1) .95s forwards;
    }
    .footer-note a {
        color: var(--ink);
        font-weight: 500;
        text-decoration: none;
        border-bottom: 1px solid var(--ink);
    }

    .panel-right {
        background: var(--ink);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }
    .panel-right::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(ellipse 60% 50% at 70% 70%, rgba(200,75,47,.18) 0%, transparent 70%),
            radial-gradient(ellipse 40% 60% at 20% 20%, rgba(200,75,47,.08) 0%, transparent 70%);
    }
    .deco { position: absolute; border-radius: 50%; border: 1px solid rgba(245,240,232,.07); }
    .deco-1 { width: 420px; height: 420px; top: -120px; left: -160px; }
    .deco-2 { width: 260px; height: 260px; top:   60px; left:  -60px; }
    .deco-3 { width: 180px; height: 180px; bottom: 100px; right: 40px; }

    .brand-word {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(5rem, 10vw, 9rem);
        line-height: .92;
        color: var(--paper);
        letter-spacing: -.02em;
        opacity: 0;
        transform: translateY(24px);
        animation: rise .9s cubic-bezier(.16,1,.3,1) .1s forwards;
        position: relative;
        z-index: 1;
    }
    .brand-word em { font-style: italic; color: var(--accent); }

    .brand-tagline {
        margin-top: 1.25rem;
        font-size: .875rem;
        color: var(--muted);
        letter-spacing: .12em;
        text-transform: uppercase;
        opacity: 0;
        animation: rise .9s cubic-bezier(.16,1,.3,1) .3s forwards;
        position: relative;
        z-index: 1;
    }

    @@keyframes rise {
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 760px) {
        .page { grid-template-columns: 1fr; }
        .panel-right { min-height: 220px; justify-content: flex-end; }
        .panel-left { padding: 2rem 1.5rem; }
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

<div class="page">

    <div class="panel-left">

        <div class="form-header">
            <h1>Create account</h1>
            <p>Join Workshop to manage your wardrobe.</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error" role="alert">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert-success" role="status">@successMessage</div>
        }

        <div class="register-form">

            <div class="field-group">
                <label for="email">Email address</label>
                <input id="email" type="email" autocomplete="email"
                       placeholder="you@example.com"
                       class="@(showErrors && string.IsNullOrWhiteSpace(email) ? "invalid" : "")"
                       @bind="email" @bind:event="oninput" />
                @if (showErrors && string.IsNullOrWhiteSpace(email))
                {
                    <span class="field-error">Email is required.</span>
                }
            </div>

            <div class="field-group">
                <label for="phone">Phone number</label>
                <input id="phone" type="tel" autocomplete="tel"
                       placeholder="8 digits"
                       class="@(showErrors && !IsValidPhone(phoneNumber) ? "invalid" : "")"
                       @bind="phoneNumber" @bind:event="oninput" />
                @if (showErrors && !IsValidPhone(phoneNumber))
                {
                    <span class="field-error">Phone number must be exactly 8 digits.</span>
                }
            </div>

            <div class="field-group">
                <label for="password">Password</label>
                <input id="password" type="password" autocomplete="new-password"
                       placeholder="At least 6 characters"
                       class="@(showErrors && password.Length < 6 ? "invalid" : "")"
                       @bind="password" @bind:event="oninput" />
                @if (showErrors && password.Length < 6)
                {
                    <span class="field-error">Password must be at least 6 characters.</span>
                }
            </div>

            <div class="field-group">
                <label for="confirmPassword">Confirm password</label>
                <input id="confirmPassword" type="password" autocomplete="new-password"
                       placeholder="••••••••"
                       class="@(showErrors && confirmPassword != password ? "invalid" : "")"
                       @bind="confirmPassword" @bind:event="oninput" />
                @if (showErrors && confirmPassword != password)
                {
                    <span class="field-error">Passwords do not match.</span>
                }
            </div>

            <div class="field-group" style="animation-delay:.7s">
                <button class="btn-register" @onclick="HandleRegister" disabled="@isLoading">
                    <span>@(isLoading ? "Creating account…" : "Create account")</span>
                </button>
            </div>

            <div class="divider">or</div>

            <p class="footer-note">
                Already have an account? <a href="/login">Sign in</a>
            </p>

        </div>
    </div>

    <div class="panel-right">
        <div class="deco deco-1"></div>
        <div class="deco deco-2"></div>
        <div class="deco deco-3"></div>
        <p class="brand-word">Work<em>shop</em></p>
        <p class="brand-tagline">Your clothing, curated</p>
    </div>

</div>

@code {
    private string email           = string.Empty;
    private string phoneNumber     = string.Empty;
    private string password        = string.Empty;
    private string confirmPassword = string.Empty;
    private string errorMessage    = string.Empty;
    private string successMessage  = string.Empty;
    private bool   isLoading       = false;
    private bool   showErrors      = false;

    // Matches Core.Model.User
    private class RegisterDto
    {
        public string Email        { get; set; } = string.Empty;
        public string PhoneNumber  { get; set; } = string.Empty;
        public string PasswordHash { get; set; } = string.Empty; // field name matches User model
    }

    private bool IsValidPhone(string phone) =>
        !string.IsNullOrEmpty(phone) && phone.Length == 8 && phone.All(char.IsDigit);

    private async Task HandleRegister()
    {
        showErrors    = true;
        errorMessage  = string.Empty;
        successMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(email) ||
            !IsValidPhone(phoneNumber) ||
            password.Length < 6 ||
            confirmPassword != password)
            return;

        isLoading = true;

        try
        {
            // POST api/User/register — matches [HttpPost("register")] in UserController
            var response = await Http.PostAsJsonAsync("api/User/register", new RegisterDto
            {
                Email        = email,
                PhoneNumber  = phoneNumber,
                PasswordHash = password  // send as plain text for now; hash server-side ideally
            });

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Account created! Redirecting to login…";
                await Task.Delay(1500);
                Nav.NavigateTo("/login");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                errorMessage = await response.Content.ReadAsStringAsync();
            }
            else
            {
                errorMessage = "Registration failed. Please try again.";
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Unable to reach the server. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
