@page "/login"
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Login — Workshop</PageTitle>

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --ink:      #0f0e0d;
        --paper:    #f5f0e8;
        --accent:   #c84b2f;
        --muted:    #8a8070;
        --border:   #d6cfc2;
        --field-bg: #ede8de;
    }

    html, body {
        height: 100%;
        background: var(--paper);
        color: var(--ink);
        font-family: 'DM Sans', sans-serif;
        font-weight: 300;
    }

    .page {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 480px;
    }

    .panel-left {
        background: var(--ink);
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }
    .panel-left::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(ellipse 60% 50% at 30% 70%, rgba(200,75,47,.18) 0%, transparent 70%),
            radial-gradient(ellipse 40% 60% at 80% 20%, rgba(200,75,47,.08) 0%, transparent 70%);
    }
    .deco { position: absolute; border-radius: 50%; border: 1px solid rgba(245,240,232,.07); }
    .deco-1 { width: 420px; height: 420px; top: -120px; right: -160px; }
    .deco-2 { width: 260px; height: 260px; top:   60px; right:  -60px; }
    .deco-3 { width: 180px; height: 180px; bottom: 100px; left:  40px; }

    .brand-word {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(5rem, 10vw, 9rem);
        line-height: .92;
        color: var(--paper);
        letter-spacing: -.02em;
        opacity: 0;
        transform: translateY(24px);
        animation: rise .9s cubic-bezier(.16,1,.3,1) .1s forwards;
        position: relative;
        z-index: 1;
    }
    .brand-word em { font-style: italic; color: var(--accent); }

    .brand-tagline {
        margin-top: 1.25rem;
        font-size: .875rem;
        color: var(--muted);
        letter-spacing: .12em;
        text-transform: uppercase;
        opacity: 0;
        animation: rise .9s cubic-bezier(.16,1,.3,1) .3s forwards;
        position: relative;
        z-index: 1;
    }

    .panel-right {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 3rem 3.5rem;
        background: var(--paper);
    }

    .form-header {
        margin-bottom: 2.5rem;
        opacity: 0;
        animation: rise .8s cubic-bezier(.16,1,.3,1) .4s forwards;
    }
    .form-header h1 {
        font-family: 'DM Serif Display', serif;
        font-size: 2rem;
        font-weight: 400;
        letter-spacing: -.01em;
        margin-bottom: .35rem;
    }
    .form-header p { font-size: .875rem; color: var(--muted); }

    .login-form { display: flex; flex-direction: column; gap: 1.25rem; }

    .field-group {
        opacity: 0;
        animation: rise .8s cubic-bezier(.16,1,.3,1) forwards;
    }
    .field-group:nth-child(1) { animation-delay: .5s; }
    .field-group:nth-child(2) { animation-delay: .6s; }
    .field-group:nth-child(3) { animation-delay: .7s; }

    .field-group label {
        display: block;
        font-size: .75rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: .5rem;
    }
    .field-group input {
        width: 100%;
        padding: .85rem 1rem;
        background: var(--field-bg);
        border: 1.5px solid transparent;
        border-radius: 6px;
        font-family: 'DM Sans', sans-serif;
        font-size: .95rem;
        color: var(--ink);
        transition: border-color .2s, background .2s;
        outline: none;
    }
    .field-group input:focus { border-color: var(--accent); background: #fff; }
    .field-group input::placeholder { color: var(--muted); }

    .alert-error {
        background: #fdf0ed;
        border: 1px solid #f2c4b8;
        border-left: 3px solid var(--accent);
        border-radius: 6px;
        padding: .75rem 1rem;
        font-size: .85rem;
        color: #8b2615;
        margin-bottom: 1rem;
        animation: rise .5s cubic-bezier(.16,1,.3,1) forwards;
    }

    .btn-login {
        margin-top: .5rem;
        padding: .9rem;
        background: var(--ink);
        color: var(--paper);
        font-family: 'DM Sans', sans-serif;
        font-size: .9rem;
        font-weight: 500;
        letter-spacing: .06em;
        text-transform: uppercase;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: background .2s;
        opacity: 0;
        animation: rise .8s cubic-bezier(.16,1,.3,1) .75s forwards;
        width: 100%;
    }
    .btn-login::after {
        content: '';
        position: absolute;
        inset: 0;
        background: var(--accent);
        transform: translateX(-100%);
        transition: transform .35s cubic-bezier(.16,1,.3,1);
    }
    .btn-login:hover::after { transform: translateX(0); }
    .btn-login:disabled { opacity: .6; cursor: not-allowed; }
    .btn-login span { position: relative; z-index: 1; }

    .divider {
        display: flex;
        align-items: center;
        gap: .75rem;
        color: var(--muted);
        font-size: .78rem;
        letter-spacing: .08em;
        text-transform: uppercase;
        opacity: 0;
        animation: rise .8s cubic-bezier(.16,1,.3,1) .85s forwards;
    }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    .footer-note {
        text-align: center;
        font-size: .82rem;
        color: var(--muted);
        opacity: 0;
        animation: rise .8s cubic-bezier(.16,1,.3,1) .95s forwards;
    }
    .footer-note a {
        color: var(--ink);
        font-weight: 500;
        text-decoration: none;
        border-bottom: 1px solid var(--ink);
    }

    @@keyframes rise {
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 760px) {
        .page { grid-template-columns: 1fr; }
        .panel-left { min-height: 220px; justify-content: flex-end; }
        .panel-right { padding: 2rem 1.5rem; }
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

<div class="page">

    <div class="panel-left">
        <div class="deco deco-1"></div>
        <div class="deco deco-2"></div>
        <div class="deco deco-3"></div>
        <p class="brand-word">Work<em>shop</em></p>
        <p class="brand-tagline">Your clothing, curated</p>
    </div>

    <div class="panel-right">

        <div class="form-header">
            <h1>Welcome back</h1>
            <p>Sign in to your account to continue.</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error" role="alert">@errorMessage</div>
        }

        <div class="login-form">

            <div class="field-group">
                <label for="email">Email address</label>
                <input id="email"
                       type="email"
                       autocomplete="email"
                       placeholder="you@example.com"
                       @bind="email"
                       @bind:event="oninput" />
            </div>

            <div class="field-group">
                <label for="password">Password</label>
                <input id="password"
                       type="password"
                       autocomplete="current-password"
                       placeholder="••••••••"
                       @bind="password"
                       @bind:event="oninput" />
            </div>

            <div class="field-group" style="animation-delay:.65s">
                <button class="btn-login" @onclick="HandleLogin" disabled="@isLoading">
                    <span>@(isLoading ? "Signing in…" : "Sign in")</span>
                </button>
            </div>

            <div class="divider">or</div>

            <p class="footer-note">
                Don't have an account? <a href="/register">Create one</a>
            </p>

        </div>
    </div>
</div>

@code {
    private string email       = string.Empty;
    private string password    = string.Empty;
    private string errorMessage = string.Empty;
    private bool   isLoading   = false;

    private class UserDto
    {
        public string? Id       { get; set; }
        public string? Email    { get; set; }
        public string? Password { get; set; }
    }

    private async Task HandleLogin()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please enter your email and password.";
            return;
        }

        isLoading = true;

        try
        {
            // Calls GET http://localhost:5168/api/User/{email}
            // Adjust the route to match your UserController
            var response = await Http.GetAsync($"api/User/{Uri.EscapeDataString(email)}");

            if (response.StatusCode == System.Net.HttpStatusCode.NotFound || !response.IsSuccessStatusCode)
            {
                errorMessage = "No account found with that email address.";
                return;
            }

            var user = await response.Content.ReadFromJsonAsync<UserDto>();

            if (user is null)
            {
                errorMessage = "Something went wrong. Please try again.";
                return;
            }

            // ⚠️ Replace with a proper hash check once passwords are hashed
            if (user.Password != password)
            {
                errorMessage = "Incorrect password. Please try again.";
                return;
            }

            // Success — navigate to home
            Nav.NavigateTo("/");
        }
        catch (HttpRequestException)
        {
            errorMessage = "Unable to reach the server. Please try again later.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
